{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Inkbox Music",
  "version": "1.1.2",
  "identifier": "com.inkbox.music",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Inkbox Music",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; img-src 'self' asset: http://asset.localhost blob: data:; media-src 'self' asset: http://asset.localhost blob:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost https://lrclib.net",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../example_song/Don Toliver - After Party.mp3": "example_song/Don Toliver - After Party.mp3",
      "../example_song/Don Toliver - After Party.lrc": "example_song/Don Toliver - After Party.lrc"
    }
  }
}
